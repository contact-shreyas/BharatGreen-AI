# ── Backend (set these on Render) ─────────────────────────────────────────────
# NVIDIA NIM API key (get one at https://build.nvidia.com)
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxx
NVIDIA_API_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=nvidia/llama-3.1-nemotron-70b-instruct

# CORS origins allowed to call the backend (comma-separated, or "*")
CORS_ORIGINS=*

# ── Frontend (set these on Vercel) ────────────────────────────────────────────
# Backend API base URL — set to your Render URL, e.g.:
NEXT_PUBLIC_API_URL=https://bharatgreen-ai-backend.onrender.com/api/v1

# Electricity Maps API key (optional — enables live grid-intensity layer)
ELECTRICITY_MAPS_API_KEY=your-electricity-maps-key
